# Identifiants du compte Atlantic Cozytouch (l'app mobile)
COZYTOUCH_USERNAME=ton.email@example.com
COZYTOUCH_PASSWORD=ton_mot_de_passe

# Serveur Overkiz cible. Pour Atlantic Cozytouch laisser tel quel.
# Valeurs possibles (extraites de pyoverkiz.enums.Server) :
#   atlantic_cozytouch, thermor_cozytouch, sauter_cozytouch,
#   somfy_europe, somfy_america, somfy_oceania, somfy_developer_mode,
#   hi_kumo_asia, hi_kumo_europe, hi_kumo_oceania,
#   brandt, flexom, hexaom_hexaconnect, nexity, rexel,
#   simu_livein2, ubiwizz
COZYTOUCH_SERVER=atlantic_cozytouch

# Optionnel : JWT pré-généré si l'auth login/password ne passe pas
# (cas connu sur certains comptes Atlantic récents). Vide par défaut.
COZYTOUCH_TOKEN=

# Fichier où sont stockés les presets. En Docker, docker-compose force /data/presets.json.
# En local, laisse vide pour utiliser le défaut (./data/presets.json).
PRESETS_FILE=

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Port d'écoute (par défaut 8000)
PORT=8000
